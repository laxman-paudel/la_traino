generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TRAINER
  TRAINEE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email        String       @unique
  password     String?
  role         Role         @default(TRAINEE)
  googleId     String?      @unique
  profileImage String?
  authProvider AuthProvider @default(LOCAL)
  isActive    Boolean      @default(true)
  bio         String?
  gender      String?
  age         Int?
  height      Float?
  weight      Float?
  location    String?
  preferences Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  trainerProfile   TrainerProfile?
  traineeProfile   TraineeProfile?
  trainerLinks     TrainerLink[]    @relation("TrainerLinks")
  traineeLinks     TrainerLink[]    @relation("TraineeLinks")
  assignedWorkoutsAsTrainer AssignedWorkout[] @relation("AssignedWorkoutTrainer")
  assignedWorkoutsAsTrainee AssignedWorkout[] @relation("AssignedWorkoutTrainee")
  workoutLogs               WorkoutLog[]
  dietPlansAsTrainer        DietPlan[]        @relation("DietPlanTrainer")
  dietPlansAsTrainee        DietPlan[]        @relation("DietPlanTrainee")
  feedbackGiven             Feedback[]        @relation("FeedbackGiven")
  feedbackReceived          Feedback[]        @relation("FeedbackReceived")
  workoutPresets            TrainerWorkoutPreset[]
  dietPresets               TrainerDietPreset[]
  exercises                 Exercise[]
  workoutTemplates          WorkoutTemplate[]
  foodItems                 FoodItem[]
  dietTemplates             DietTemplate[]
  coachingNotesGiven        CoachingNote[]    @relation("CoachingNoteTrainer")
  coachingNotesReceived     CoachingNote[]    @relation("CoachingNoteTrainee")
  exerciseCommentsGiven     ExerciseComment[] @relation("ExerciseCommentTrainer")
  exerciseCommentsReceived  ExerciseComment[] @relation("ExerciseCommentTrainee")
  dietCommentsGiven         DietComment[]     @relation("DietCommentTrainer")
  dietCommentsReceived      DietComment[]     @relation("DietCommentTrainee")
}

model TrainerProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  trainerCode     String   @unique
  bio             String?
  specialties     String?
  yearsExperience Int?
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TraineeProfile {
  id                  Int           @id @default(autoincrement())
  userId              Int           @unique
  fitnessGoal         String?
  dateOfBirth         DateTime?
  selectedPresetId    Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedPreset PresetWorkout? @relation(fields: [selectedPresetId], references: [id], onDelete: SetNull)
}

model TrainerLink {
  id         Int      @id @default(autoincrement())
  trainerId  Int
  traineeId  Int      @unique
  createdAt  DateTime @default(now())

  trainer User @relation("TrainerLinks", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("TraineeLinks", fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}

model PresetWorkout {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  days         PresetWorkoutDay[]
  traineeSelections TraineeProfile[]
}

model PresetWorkoutDay {
  id        Int    @id @default(autoincrement())
  presetId  Int
  dayNumber Int
  name      String?
  createdAt DateTime @default(now())

  preset    PresetWorkout           @relation(fields: [presetId], references: [id], onDelete: Cascade)
  exercises PresetWorkoutExercise[]

  @@unique([presetId, dayNumber])
  @@index([presetId])
}

model PresetWorkoutExercise {
  id     Int    @id @default(autoincrement())
  dayId  Int
  name   String
  sets   Int
  reps   Int
  createdAt DateTime @default(now())

  day PresetWorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model AssignedWorkout {
  id        Int      @id @default(autoincrement())
  trainerId Int
  traineeId Int
  day       DateTime
  name      String?
  exercises Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer User @relation("AssignedWorkoutTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("AssignedWorkoutTrainee", fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([traineeId, day])
  @@index([trainerId, traineeId])
}

model WorkoutLog {
  id          Int        @id @default(autoincrement())
  traineeId   Int
  day         DateTime
  exercises   Json
  progress    Json?
  completed   Boolean    @default(false)
  completedAt DateTime?
  note        String?
  createdAt   DateTime   @default(now())

  trainee User @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([traineeId, day])
}

model DietPlan {
  id          Int        @id @default(autoincrement())
  trainerId   Int
  traineeId   Int
  day         DateTime
  meals       Json
  progress    Json?
  completed   Boolean    @default(false)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  trainer User @relation("DietPlanTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("DietPlanTrainee", fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([traineeId, day])
  @@index([trainerId, traineeId])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  trainerId Int
  traineeId Int
  weekStart DateTime?
  message   String
  title     String?
  priority  String?
  category  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  trainer User @relation("FeedbackGiven", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("FeedbackReceived", fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([traineeId])
  @@index([trainerId, traineeId])
}

model CoachingNote {
  id        Int      @id @default(autoincrement())
  trainerId Int
  traineeId Int
  title     String
  message   String
  priority  String?
  category  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  trainer User @relation("CoachingNoteTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("CoachingNoteTrainee", fields: [traineeId], references: [id], onDelete: Cascade)

  @@index([trainerId, traineeId])
  @@index([traineeId])
}

model ExerciseComment {
  id           Int      @id @default(autoincrement())
  trainerId    Int
  traineeId    Int
  exerciseName String
  comment      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trainer User @relation("ExerciseCommentTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("ExerciseCommentTrainee", fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([trainerId, traineeId, exerciseName])
  @@index([trainerId, traineeId])
}

model DietComment {
  id        Int      @id @default(autoincrement())
  trainerId Int
  traineeId Int
  mealType  String
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer User @relation("DietCommentTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainee User @relation("DietCommentTrainee", fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([trainerId, traineeId, mealType])
  @@index([trainerId, traineeId])
}

model WorkoutTemplate {
  id               Int      @id @default(autoincrement())
  trainerId        Int
  name             String
  description      String?
  difficulty       String?
  estimatedDuration Int?
  exercises        Json
  archived         Boolean  @default(false)
  favorited        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}

model TrainerWorkoutPreset {
  id               Int      @id @default(autoincrement())
  trainerId        Int
  name             String
  description      String?
  difficulty       String?
  estimatedDuration Int?
  exercises        Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}

model TrainerDietPreset {
  id          Int      @id @default(autoincrement())
  trainerId   Int
  name        String
  description String?
  meals       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}

model GlobalWorkoutPreset {
  id               Int      @id @default(autoincrement())
  name             String
  description      String?
  category         String?
  difficulty       String?
  tags             Json?
  exercises        Json
  estimatedDuration Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GlobalDietPreset {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  category    String?
  difficulty  String?
  tags        Json?
  meals       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exercise {
  id               Int      @id @default(autoincrement())
  name             String
  category         String
  description      String?
  equipment        String?
  difficulty       String?
  primaryMuscles   Json?
  secondaryMuscles Json?
  instructions     String?
  tips             String?
  commonMistakes   String?
  imageUrl         String?
  youtubeUrl       String?
  trainerId        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trainer User? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([category])
}

model FoodItem {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  servingSize String?
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  imageUrl    String?
  description String?
  trainerId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainer User? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([category])
}

model DietTemplate {
  id          Int      @id @default(autoincrement())
  trainerId   Int
  name        String
  description String?
  meals       Json
  archived    Boolean  @default(false)
  favorited   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
}
